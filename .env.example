# ============================================================================
# AMBIENTE COMUM
# ============================================================================
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
PORT=8080
FLASK_DEBUG=false
WAIT_TIME_SECONDS=10

# ============================================================================
# DESENVOLVIMENTO LOCAL (LocalStack)
# ============================================================================
# Descomente esta seção para rodar localmente com LocalStack
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# SNS_TOPIC_NAME=pedidos
# SQS_QUEUE_NAME=pedidos-queue
# SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:pedidos
# SQS_QUEUE_URL=http://localhost:4566/000000000000/pedidos-queue
# SQS_QUEUE_ARN=arn:aws:sqs:us-east-1:000000000000:pedidos-queue

# ============================================================================
# PRODUÇÃO (EC2 com IAM Role)
# ============================================================================
# DEIXE AS CREDENCIAIS EM BRANCO — boto3 detecta automaticamente via IAM Role
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Preencha os ARNs/URLs após criar SNS/SQS na AWS
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:pedidos
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/pedidos-queue
SQS_QUEUE_ARN=arn:aws:sqs:us-east-1:123456789012:pedidos-queue

